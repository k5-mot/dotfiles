#!/bin/zsh

## Separator symbols
SEPARATOR_LEFT="\ue0b0"
SEPARATOR_RIGHT="\ue0b2 "
SUBSEPARATOR_LEFT="\ue0b1 "
SUBSEPARATOR_RIGHT="\ue0b3 "

## Git symbols
UNSTAGE="\uf658"
STAGE="\uf071"
COMMIT="\uf058"


if git_status=$(cd $1 && git status 2>/dev/null ); then
  git_branch="$(echo $git_status | awk 'NR==1 {print $3}')"
  case $git_status in
    *Changes\ not\ staged* )
      git_symbol=${UNSTAGE} ;;
    *Changes\ to\ be\ committed* )
      git_symbol=${STAGE} ;;
    * )
      git_symbol=${COMMIT} ;;
  esac
  case $git_branch in
    master )
      git_info="#[bg=colour148]${SEPARATOR_LEFT}#[bg=colour148,fg=colour022] ${git_branch} ${git_symbol} #[bg=default,fg=colour148]${SEPARATOR_LEFT}" ;;
    develop )
      git_info="#[bg=colour024]${SEPARATOR_LEFT}#[bg=colour024,fg=colour117] ${git_branch} ${git_symbol} #[bg=default,fg=colour024]${SEPARATOR_LEFT}" ;;
    *feature* )
      git_info="#[bg=colour208]${SEPARATOR_LEFT}#[bg=colour208,fg=colour088] ${git_branch} ${git_symbol} #[bg=default,fg=colour208]${SEPARATOR_LEFT}" ;;
    release )
      git_info="#[bg=colour055]${SEPARATOR_LEFT}#[bg=colour055,fg=colour189] ${git_branch} ${git_symbol} #[bg=default,fg=colour055]${SEPARATOR_LEFT}" ;;
    *hotfix* )
      git_info="#[bg=colour196]${SEPARATOR_LEFT}#[bg=colour196,fg=colour250] ${git_branch} ${git_symbol} #[bg=default,fg=colour196]${SEPARATOR_LEFT}" ;;
    * )
      git_info="#[bg=colour252]${SEPARATOR_LEFT}#[bg=colour252,fg=colour241] ${git_branch} ${git_symbol} #[bg=default,fg=colour252]${SEPARATOR_LEFT}" ;;
  esac
else
  git_info="#[bg=default]${SEPARATOR_LEFT}"
fi

echo "$git_info"
