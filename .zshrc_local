# connect to my machine
if [ $HOSTNAME = penguin.cis.nagasaki-u.ac.jp ]; then
  eval 'ssh firebird'
fi

# set up aliases
alias bes-master='ssh b317048@bes-master.cis.nagasaki-u.ac.jp'

# set up libraries
if [ $OSTYPE = linux-gnu -o $OSTYPE = linux ]; then

  # Shared Library
  export LD_LIBRARY_PATH=/usr/local/lib
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/gcc/lib
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/compositeproto-0.4.2/lib/
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/libXcomposite-0.4.5/lib/
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/scrnsaverproto-1.2.2/lib/
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/libXScrnSaver-1.2.3/lib/
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/compositeproto-0.4.2/lib64/
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/libXcomposite-0.4.5/lib64/
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/scrnsaverproto-1.2.2/lib64/
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/libXScrnSaver-1.2.3/lib64/
  #export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/glibc-2_18/lib
  #export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$HOME/Bin/gcc/lib64

  ## Run path
  export LD_RUN_PATH=/usr/local/lib
  export LD_RUN_PATH=$LD_RUN_PATH:$HOME/Bin/compositeproto-0.4.2/lib/
  export LD_RUN_PATH=$LD_RUN_PATH:$HOME/Bin/libXcomposite-0.4.5/lib/
  export LD_RUN_PATH=$LD_RUN_PATH:$HOME/Bin/scrnsaverproto-1.2.2/lib/
  export LD_RUN_PATH=$LD_RUN_PATH:$HOME/Bin/libXScrnSaver-1.2.3/lib/
  export LD_RUN_PATH=$LD_RUN_PATH:$HOME/Bin/compositeproto-0.4.2/lib64/
  export LD_RUN_PATH=$LD_RUN_PATH:$HOME/Bin/libXcomposite-0.4.5/lib64/
  export LD_RUN_PATH=$LD_RUN_PATH:$HOME/Bin/scrnsaverproto-1.2.2/lib64/
  export LD_RUN_PATH=$LD_RUN_PATH:$HOME/Bin/libXScrnSaver-1.2.3/lib64/

  # pkg-config
  export PKG_CONFIG_PATH=/opt/lib/pkgconfig:$PKG_CONFIG_PATH

  # Automake
  export ACLOCAL_PATH=$ACLOCAL_PATH:/usr/local/lib/

  # Ruby libraries
  export RUBYLIB=$RUBYLIB:/usr/local/lib/

fi

# set up applications
if [ $OSTYPE = linux-gnu -o $OSTYPE = linux ]; then

  # Chromium depot_tools
  export PATH=$PATH:$HOME/Bin/sources/depot_tools

  # Chromium

  # CADENCE IUS
  export CDS_INST_DIR=/home/cad/cadence-xcelium-18.09.001
  export PATH=$PATH:$CDS_INST_DIR/tools/bin
  export CDS_LIC_FILE=5280@vdec-cad1,5280@vdec-cad2,5280@vdec-cad3
  export INCA_64BIT=1

  # ALTERA Quartus
  export QUARTUS_VERSION="pro-19.1"
  export QUARTUS_ROOTDIR=/home/cad/altera-quartus-$QUARTUS_VERSION/quartus
  export QUARTUS_ROOTDIR_OVERRIDE=/home/cad/altera-quartus-$QUARTUS_VERSION/quartus
  export SOPC_KIT_NIOS2=/home/cad/altera-quartus-$QUARTUS_VERSION/nios2eds
  export MODELSIM_ASEDIR=/home/cad/altera-quartus-$QUARTUS_VERSION/modelsim_ase
  export ALTERA_HLS_DIR=/home/cad/altera-quartus-$QUARTUS_VERSION/hls
  export ALTERAOCLSDKROOT=/home/cad/altera-quartus-$QUARTUS_VERSION/hld
  export AOCL_BOARD_PACKAGE_ROOT=$ALTERAOCLSDKROOT/board/a10_ref
  export PATH=$QUARTUS_ROOTDIR/bin:$PATH
  export PATH=$SOPC_KIT_NIOS2/bin:$PATH
  export PATH=$MODELSIM_ASEDIR/bin:$PATH
  export PATH=$QUARTUS_ROOTDIR/sopc_builder/bin:$PATH
  export PATH=$ALTERA_HLS_DIR/bin:$PATH
  export PATH=$ALTERAOCLSDKROOT/bin:$PATH
  export PATH=$ALTERAOCLSDKROOT/linux64/bin:$PATH
  export PATH=$ALTERAOCLSDKROOT/host/linux64/bin:$PATH
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$ALTERA_HLS_DIR/host/linux64/lib
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$ALTERAOCLSDKROOT/host/linux64/lib
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$AOCL_BOARD_PACKAGE_ROOT/linux64/lib
  export QUARTUS_64BIT=1
  export ALTERAD_LICENSE_FILE=2100@harrier
  export QUARTUS_MWWM="allwm"
  export LM_LICENSE_FILE=1800@133.45.242.192:$LM_LICENSE_FILE
  #source $ALTERA_HLS_DIR/init_hls.sh

  # Xilinx Vivado
  export VIVADO_VERSION=2019.1
  export XILINX_VIVADO=/home/cad/xilinx-vivado-$VIVADO_VERSION/Vivado/$VIVADO_VERSION
  export PATH=$XILINX_VIVADO/bin:$PATH
  export VIVADO_HLS=/home/cad/xilinx-vivado-$VIVADO_VERSION/Vivado_HLS/$VIVADO_VERSION
  export PATH=$VIVADO_HLS/bin:$PATH

  # GLIBC
  #export PATH=~/Bin/glibc-2_18/bin:$PATH

  # GNU C Compiler
  export PATH=~/Bin/gcc/bin:$PATH

  # GNU Binutils
  export PATH=~/Bin/binutils/bin:$PATH

  # GNU Make
  export PATH=~/Bin/gmake/bin:$PATH

  # CMake
  export PATH=~/Bin/cmake/bin:$PATH

  # Git
  export PATH=~/Bin/git/bin:$PATH

  # Vim
  export PATH=~/Bin/vim/bin:$PATH

  # NeoVim
  export PATH=~/Bin/neovim/bin:$PATH

  # Firefox
  export PATH=~/Bin/firefox:$PATH

  # VSCode
  export PATH=$PATH:~/Bin/VSCode-linux-x64/bin

  # PyCharm
  export PATH=$PATH:~/Bin/pycharm-community-2020.2/bin
  alias pycharm='bash ~/Bin/pycharm-community-2020.2/bin/pycharm.sh'

  # Eclipse
  export PATH=$PATH:~/Bin/eclipse

  # pyenv
  export PYENV_ROOT="$HOME/.pyenv"
  export PATH="$PYENV_ROOT/bin:$PATH"
  eval "$(pyenv init -)"

  # pyenv-virtualenv
  eval "$(pyenv virtualenv-init -)"

  # rbenv
  export RBENV_ROOT="$HOME/.rbenv"
  export PATH="$RBENV_ROOT/bin:$PATH"
  eval "$(rbenv init -)"

fi

